generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  EDITOR
  ADMIN
}

enum Plan {
  FREE
  PREMIUM
}

enum Surface {
  CIM
  KUM
  SENTETIK
}

enum Breed {
  ARAP
  INGILIZ
}

enum Confidence {
  DUSUK
  ORTA
  YUKSEK
}

enum PedigreeRating {
  ZAYIF
  DUSUK
  ORTA
  GUCLU
  YUKSEK
  COK_YUKSEK
  SORU
  BILINMIYOR
}

enum ArticleType {
  EDUCATIONAL
  MAGAZINE
}

enum NotificationType {
  NEW_PREDICTION
  NEW_ARTICLE
  SYSTEM
  HORSE_RACE
}

enum LessonCategory {
  DERECE
  SICIL_KILO
  AGF
  TEMPO
  TUM_ATLAR
  BANKO
  JOKEY
  GALOP
  TAKI
  GRUP
  GENEL
}

// ─── AUTH & USERS ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  hasSeenIntro  Boolean   @default(false)
  marketingConsent Boolean @default(false)

  predictions   Prediction[]
  articles      Article[]
  notifications Notification[]
  horseFollows  HorseFollow[]
  accounts      Account[]
  sessions      Session[]
  loginLogs     LoginLog[]
  pageViews     PageView[]
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ip        String
  userAgent String   @default("")
  country   String?
  city      String?
  success   Boolean
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([success])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── RACE DOMAIN ──────────────────────────────────────────────────────────────

model Hippodrome {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  raceDays RaceDay[]
}

model RaceDay {
  id                String   @id @default(cuid())
  date              DateTime
  hippodromeId      String
  createdAt         DateTime @default(now())
  surfaceConditions Json? // TJK "conditions-race" bloğu — [{label:"Çim", detail:"Normal 3,3"}, ...]
  weather           String? // örn. "Hava: 26C,Az Bulutlu,Nem%64"

  hippodrome Hippodrome @relation(fields: [hippodromeId], references: [id])
  races      Race[]

  @@unique([date, hippodromeId])
}

model Race {
  id          String   @id @default(cuid())
  raceDayId   String
  raceNo      Int
  time        String?
  classType   String
  breed       Breed
  surface     Surface
  distance    Int
  conditions  String?
  ageWeight   String?
  trackRecord String?
  createdAt   DateTime @default(now())

  raceDay    RaceDay     @relation(fields: [raceDayId], references: [id], onDelete: Cascade)
  runners    Runner[]
  prediction Prediction?
  result     Result?

  @@unique([raceDayId, raceNo])
}

model Runner {
  id               String  @id @default(cuid())
  raceId           String
  no               Int
  name             String
  sire             String?
  dam              String?
  damSire          String?
  pedigreeNote     String?
  adminNote        String?
  jockey           String?
  trainer          String?
  startNo          Int?
  weight           Float?
  weightChange     Float?
  equipment        String?
  equipmentAdded   String?
  equipmentRemoved String?
  sameJockey       Boolean @default(false)
  agf              Float?
  raceStyle        Json?
  recentForm       String?
  jockeyChanged    Boolean @default(false)
  previousJockey   String?
  age              String?
  owner            String?
  hp               Int?
  bestTime         String?
  recentFormSurfaces String?
  scratched        Boolean @default(false)
  ekuriGroup       Int?
  apprentice       Boolean @default(false)
  tjkAtId          Int?

  race         Race          @relation(fields: [raceId], references: [id], onDelete: Cascade)
  gallops      Gallop[]
  picks        Pick[]
  agfSnapshots AgfSnapshot[]

  @@unique([raceId, no])
}

/** AGF senkronizasyonu her çalıştığında (günde 4 kez) atılan an'lık AGF kaydı — zaman içindeki para hareketini (steam) görmek için. */
model AgfSnapshot {
  id         String   @id @default(cuid())
  runnerId   String
  agf        Float
  capturedAt DateTime @default(now())

  runner Runner @relation(fields: [runnerId], references: [id], onDelete: Cascade)

  @@index([runnerId, capturedAt])
}

model Gallop {
  id       String   @id @default(cuid())
  runnerId String
  date     DateTime
  track    String?
  surface  Surface?
  jockey   String?
  form     String?
  splits   Json

  runner Runner @relation(fields: [runnerId], references: [id], onDelete: Cascade)
}

// Admin-maintained sire reputation reference — powers automatic pedigree scoring.
// Tiers are domain knowledge the analyst (not the system) owns; this table just
// lets that knowledge be looked up instead of re-typed into every report.
model SireTier {
  id      String         @id @default(cuid())
  name    String         @unique
  tier    PedigreeRating
  surface Surface?
  breed   Breed?
  note    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PREDICTION ───────────────────────────────────────────────────────────────

model Prediction {
  id           String     @id @default(cuid())
  raceId       String     @unique
  authorId     String
  confidence   Confidence @default(ORTA)
  notes        String
  tempo        String?
  couponNarrow String?
  couponNormal String?
  couponWide   String?
  isBanko      Boolean    @default(false)
  bankoNote    String?
  published    Boolean    @default(false)
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
  picks  Pick[]

  @@index([published])
}

model Pick {
  id             String         @id @default(cuid())
  predictionId   String
  rank           Int
  runnerId       String?
  runnerLabel    String
  score          Int?
  details        Json
  pedigreeRating PedigreeRating @default(BILINMIYOR)
  isTarget       Boolean        @default(false)

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  runner     Runner?    @relation(fields: [runnerId], references: [id])

  @@unique([predictionId, rank])
}

// ─── RESULT ───────────────────────────────────────────────────────────────────

model Result {
  id          String   @id @default(cuid())
  raceId      String   @unique
  actualOrder Json
  winnerNo    Int?
  ganyan      Float?
  time        String? // Müddet — kazananın resmi koşu süresi (örn. "1.20.11")
  farklar     String? // Farklar — ilk sıralar arasındaki mesafe farkları, TJK sırasıyla (örn. "Baş, 1, 2, Boyun")
  hitTop1     Boolean  @default(false)
  hitInCoupon Boolean  @default(false)
  hitRanks    Json?
  errorTag    String?
  errorNote   String?
  cikan       String?
  enteredAt   DateTime @default(now())

  race    Race               @relation(fields: [raceId], references: [id], onDelete: Cascade)
  lessons PostMortemLesson[]

  @@index([hitTop1])
}

// ─── CONTENT ──────────────────────────────────────────────────────────────────

model Article {
  id              String      @id @default(cuid())
  type            ArticleType
  title           String
  slug            String      @unique
  excerpt         String?
  body            String
  coverImage      String?
  category        String?
  tags            String[]
  authorId        String
  published       Boolean     @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([type, published])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── HORSE FOLLOWS ────────────────────────────────────────────────────────────

model HorseFollow {
  id        String   @id @default(cuid())
  userId    String
  horseName String
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, horseName])
  @@index([userId])
}

// ─── CLAUDE API BÜTÇE TAKİBİ ───────────────────────────────────────────────────
// Anthropic'in kendisi kalan kredi bakiyesini API üzerinden vermiyor (yalnızca
// Console'da gösteriliyor) — bu yüzden her çağrının token kullanımını burada
// kendimiz kaydedip, admin'in girdiği başlangıç bakiyeden düşerek TAHMİNİ bir
// kalan bakiye hesaplıyoruz. Gerçek Anthropic bakiyesiyle birebir aynı olacağının
// garantisi yoktur.

model ClaudeUsageLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  raceId       String?
  phase        String // "faz2" | "faz4"
  model        String
  inputTokens  Int
  outputTokens Int

  @@index([createdAt])
}

model ClaudeBudget {
  id          String   @id @default(cuid())
  startingUsd Float
  resetAt     DateTime @default(now())
  note        String?
}

// ─── METHODOLOGY ──────────────────────────────────────────────────────────────

model MethodologyVersion {
  id            String   @id @default(cuid())
  version       String   @unique
  effectiveDate DateTime
  content       String
  isCurrent     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model PostMortemLesson {
  id        String         @id @default(cuid())
  title     String
  date      DateTime
  category  LessonCategory
  rule      String
  raceRef   String?
  resultId  String?
  tags      String[]
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  result Result? @relation(fields: [resultId], references: [id])

  @@index([category, active])
}

// ─── ANASAYFA KUPON ───────────────────────────────────────────────────────────

// Admin'in manuel kurduğu çok ayaklı kombine kupon (Ekonomik/Normal/Geniş) — anasayfada gösterilir.
model HomeKupon {
  id             String   @id @default(cuid())
  hippodromeName String
  date           DateTime
  legs           Json     // [{ raceNo: number, narrow: number[], normal: number[], wide: number[] }]
  slot           Int      @default(1) // 1 = 1. Altılı, 2 = 2. Altılı — her slot kendi başına aktif olabilir
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([slot])
}

// ─── ENGINE CONFIG ────────────────────────────────────────────────────────────

model EngineConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ─── SITE SETTINGS ───────────────────────────────────────────────────────────

model SiteSetting {
  key       String   @id  // örn. "banner_url"
  value     String
  updatedAt DateTime @updatedAt
}

// ─── BANNER SLIDES ───────────────────────────────────────────────────────────

model BannerSlide {
  id        String   @id @default(cuid())
  url       String
  storagePath String  // Supabase'deki dosya yolu (silme için)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, order])
}

// ─── JOKEY STAT SYNC (TJK'dan çekilen) ───────────────────────────────────────

model JockeyStatSync {
  id               String   @id @default(cuid())
  jockey           String
  hippoSlug        String   // "overall" veya hippodrome slug (ankara, istanbul, ...)
  year             Int
  breed            String?  // "INGILIZ" | "ARAP" | null = hepsi
  surface          String?  // "CIM" | "KUM" | "SENTETIK" | null = hepsi
  rides            Int
  wins             Int
  place2           Int
  place3           Int
  place4           Int
  place5           Int
  tableCount       Int
  winRate          Float
  tableRate        Float
  prizeTl          Int
  performanceScore Float?
  confidenceLabel  String?
  jsonCutoffDate   DateTime? // JSON import tarihi — auto-sync bu tarihten sonraki yarışları ekler
  jsonBaseline     Json?     // JSON import anındaki sabit taban (rides/wins/place2-5) — auto-sync asla üzerine yazmaz
  updatedAt        DateTime @updatedAt

  @@unique([jockey, hippoSlug, year, breed, surface])
  @@index([hippoSlug, year, breed, surface])
  @@index([jockey, year])
}

// ─── ANTRENÖR STAT SYNC (TJK'dan çekilen) ────────────────────────────────────

model TrainerStatSync {
  id        String   @id @default(cuid())
  trainer   String
  year      Int
  rides     Int
  wins      Int
  winRate   Float
  updatedAt DateTime @updatedAt

  @@unique([trainer, year])
  @@index([trainer, year])
}

// ─── PAGE VIEWS ───────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  userId    String?
  path      String
  duration  Int?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([path])
  @@index([createdAt(sort: Desc)])
}
